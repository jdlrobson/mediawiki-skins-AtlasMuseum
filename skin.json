{
	"name": "AtlasMuseum",
	"author": "A-Pack",
	"descriptionmsg": "atlasmuseum-desc",
	"namemsg": "skinname-atlasmuseum",
	"license-name": "GPL-2.0+",
	"type": "skin",
	"manifest_version": 2,
	"requires": {
		"MediaWiki": ">= 1.46.0"
	},
	"ValidSkinNames": {
		"atlasmuseum": {
			"class": "SkinAtlasMuseum",
			"args": [
				{
					"menus": [
						"user-menu",
						"notifications",
						"user-interface-preferences",
						"user-page",
						"associated-pages",
						"views",
						"actions",
						"variants"
					],
					"name": "atlasmuseum",
					"styles": [
						"skins.atlasmuseum"
					],
					"scripts": [
						"skins.atlasmuseum.js"
					],
					"template": "AtlasMuseumTemplate"
				}
			]
		}
	},
	"AutoloadClasses": {
		"SkinAtlasMuseum": "AtlasMuseum.skin.php",
		"AtlasMuseumTemplate": "AtlasMuseumTemplate.php"
	},
	"MessagesDirs": {
		"AtlasMuseum": "i18n"
	},
	"ResourceModules": {
		"skins.atlasmuseum": {
			"class": "MediaWiki\\ResourceLoader\\SkinModule",
			"features": {
				"interface": true
			},
			"styles": {
				"resources/screen.css": { "media": "screen" }
			}
		},
		"skins.atlasmuseum.js": {
			"position": "bottom",
			"scripts": [
				"resources/atlasmuseum.js"
			]
		}
	},
	"ResourceFileModulePaths": {
		"localBasePath": "",
		"remoteSkinPath": "AtlasMuseum"
	}
}
